{
  "name": "sitescope",
  "version": "1.0.0",
  "description": "Inspect any website: detect frameworks, analyze headers/cookies/SEO, map network resources, and generate reports.",
  "type": "module",
  "bin": {
    "sitescope": "bin/sitescope.js",
    "sitescope-ui": "bin/sitescope-ui.js"
  },
  "scripts": {
    "start": "node bin/sitescope.js",
    "ui": "node bin/sitescope-ui.js",
    "ui:next": "npm --prefix ui-next run dev",
    "ui:next:build": "npm --prefix ui-next run build"
  },
  "keywords": [
    "cli",
    "web",
    "seo",
    "framework-detection",
    "headers",
    "security",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
